{
  "editor.defaultFormatter": "dprint.dprint",
  "editor.formatOnSave": true,
  "[github-actions-workflow]": {
    "editor.defaultFormatter": "dprint.dprint"
  },
  "[go]": {
    "editor.defaultFormatter": "golang.go",
    "editor.formatOnSave": true,
    "editor.formatOnPaste": true
  },
  "[json]": {
    "editor.defaultFormatter": "dprint.dprint"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "dprint.dprint"
  },
  "[markdown]": {
    "editor.defaultFormatter": "dprint.dprint"
  },
  "[toml]": {
    "editor.defaultFormatter": "dprint.dprint"
  },
  "[yaml]": {
    "editor.defaultFormatter": "dprint.dprint"
  },
  "gopls": {
    "build.directoryFilters": [
      "-**/dagger.gen.go"
      // "+.dagger"
    ]
  }
}
